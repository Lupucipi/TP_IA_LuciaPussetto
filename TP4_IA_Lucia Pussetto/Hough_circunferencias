import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import math

# =====================================================================
# 1. FILTRO DE CONTORNOS (MAGNITUD DE GRADIENTE)
# =====================================================================
def detectar_bordes_magnitud(imagen_gris, umbral_gradiente=100):
    """
    Mantiene la misma lógica que usamos para las rectas.
    Aísla los contornos fuertes del motor eliminando texturas.
    """
    img_arr = np.array(imagen_gris, dtype=float)
    diff_x = np.zeros_like(img_arr)
    diff_y = np.zeros_like(img_arr)
    
    diff_x[:, :-1] = np.diff(img_arr, axis=1)
    diff_y[:-1, :] = np.diff(img_arr, axis=0)
    
    magnitud = np.sqrt(diff_x**2 + diff_y**2)
    bordes = np.zeros_like(img_arr)
    bordes[magnitud > umbral_gradiente] = 1
    return bordes

# =====================================================================
# 2. ACUMULADOR TRIDIMENSIONAL DE HOUGH PARA CÍRCULOS
# =====================================================================
def transformada_hough_circulos(imagen_bordes, r_min, r_max, paso_r=1):
    """
    Genera un espacio paramétrico 3D (Centro X, Centro Y, Radio R).
    Cada píxel blanco vota por los posibles centros de un círculo.
    """
    alto, ancho = imagen_bordes.shape
    
    # Creamos el rango de radios que nos interesa explorar
    radios = np.arange(r_min, r_max + 1, paso_r)
    
    # Inicializamos el ACUMULADOR 3D (Cubo de memoria)
    acumulador = np.zeros((alto, ancho, len(radios)), dtype=int)
    
    # Precomputamos ángulos de 0 a 360 grados (paso de 2° para acelerar el cálculo)
    thetas = np.deg2rad(np.arange(0, 360, 2))
    cos_t = np.cos(thetas)
    sin_t = np.sin(thetas)
    
    # Localizamos los píxeles de borde activos
    y_idxs, x_idxs = np.nonzero(imagen_bordes)
    
    print(f"Calculando votación tridimensional para {len(x_idxs)} píxeles...")
    
    # Recorremos cada píxel de borde
    for i in range(len(x_idxs)):
        x = x_idxs[i]
        y = y_idxs[i]
        
        # Evaluamos para cada radio del rango elegido
        for r_idx, r in enumerate(radios):
            # Ecuación paramétrica del círculo: calculamos las coordenadas del posible centro (a, b)
            a_centros = (x - r * cos_t).astype(int)
            b_centros = (y - r * sin_t).astype(int)
            
            # Filtro de seguridad: nos aseguramos de que el centro calculado caiga dentro de la imagen
            validos = (a_centros >= 0) & (a_centros < ancho) & (b_centros >= 0) & (b_centros < alto)
            
            # Sumamos un voto en el cubo 3D a las posiciones válidas
            acumulador[b_centros[validos], a_centros[validos], r_idx] += 1
            
    return acumulador, radios

# =====================================================================
# 3. SUPRESIÓN DE NO MÁXIMOS 3D (Fusión de esferas de votación)
# =====================================================================
def encontrar_centros_nms(acumulador, radios, umbral_votos, vecindad_espacio=25, vecindad_radio=10):
    """
    Busca los picos en el espacio 3D y fusiona círculos que tengan 
    centros y radios demasiado similares.
    """
    # Encontramos todas las coordenadas del cubo que superen el umbral de votos
    b_picos, a_picos, r_picos = np.where(acumulador > umbral_votos)
    votos = acumulador[b_picos, a_picos, r_picos]
    
    # Ordenamos de mayor a menor cantidad de votos
    indices_ordenados = np.argsort(votos)[::-1]
    
    circulos_confirmados = []
    
    for idx in indices_ordenados:
        b_centro = b_picos[idx]
        a_centro = a_picos[idx]
        r_actual = radios[r_picos[idx]]
        
        es_maximo_local = True
        
        # Comparamos contra los círculos ya aceptados
        for ca, cb, cr in circulos_confirmados:
            # Distancia euclídea entre los centros en el plano
            dist_centros = math.sqrt((a_centro - ca)**2 + (b_centro - cb)**2)
            # Diferencia absoluta entre sus radios
            dist_radio = abs(r_actual - cr)
            
            # Si el centro está cerca Y el radio es parecido, es el mismo objeto duplicado
            if dist_centros < vecindad_espacio and dist_radio < vecindad_radio:
                es_maximo_local = False
                break
                
        if es_maximo_local:
            circulos_confirmados.append((a_centro, b_centro, r_actual))
            
    return circulos_confirmados

