import numpy as np
import matplotlib.pyplot as plt
from PIL import Image

def detectar_bordes_basico(imagen_gris, umbral=100):
    """Filtro de contornos básico basado en diferencias de píxeles adyacentes"""
    img_arr = np.array(imagen_gris, dtype=float)
    diff_x = np.zeros_like(img_arr)
    diff_y = np.zeros_like(img_arr)
    diff_x[:, :-1] = np.diff(img_arr, axis=1)
    diff_y[:-1, :] = np.diff(img_arr, axis=0)
    magnitud = np.sqrt(diff_x**2 + diff_y**2)
    bordes = np.zeros_like(img_arr)
    bordes[magnitud > umbral] = 1
    return bordes

def hough_circulos_2d_clasico(imagen_bordes, radio_conocido):
    """
    Mapea píxeles del espacio de la imagen a un espacio de parámetros (a, b) 2D,
    dibujando un círculo de votos de radio 'r' alrededor de cada píxel activo.
    """
    alto, ancho = imagen_bordes.shape
    
    # 1. El espacio de parámetros A(a,b) 
    acumulador = np.zeros((alto, ancho), dtype=int)
    
    # 2. Precomputamos los valores de seno y coseno para todos los ángulos posibles
    thetas = np.deg2rad(np.arange(0, 360, 1)) # Ángulos de 0 a 359
    cos_t = np.cos(thetas)
    sin_t = np.sin(thetas)
    
    # 3. Buscamos todos los píxeles de borde
    y_idxs, x_idxs = np.nonzero(imagen_bordes)
    
    print(f"Dibujando {len(x_idxs)} círculos de votación de radio {radio_conocido}...")
    
    # 4. Proceso de votación
    for i in range(len(x_idxs)):
        x = x_idxs[i]
        y = y_idxs[i]
        
        # Generamos las coordenadas del círculo de votación
        a_votos = np.round(x - radio_conocido * cos_t).astype(int)
        b_votos = np.round(y - radio_conocido * sin_t).astype(int)
        
        # Filtramos para no salirnos de los márgenes de la matriz
        validos = (a_votos >= 0) & (a_votos < ancho) & (b_votos >= 0) & (b_votos < alto)
        
        # Sumamos un voto en todo ese perímetro dibujado
        acumulador[b_votos[validos], a_votos[validos]] += 1
        
    return acumulador

def extraer_centros_2d(acumulador, umbral_votos, radio, vecindad=20):
    """Extrae los picos del acumulador 2D usando Supresión de No Máximos"""
    b_picos, a_picos = np.where(acumulador > umbral_votos)
    votos = acumulador[b_picos, a_picos]
    indices_ordenados = np.argsort(votos)[::-1]
    
    centros_filtrados = []
    
    for idx in indices_ordenados:
        a = a_picos[idx]
        b = b_picos[idx]
        es_maximo = True
        
        for ca, cb, cr in centros_filtrados:
            dist = np.sqrt((a - ca)**2 + (b - cb)**2)
            if dist < vecindad:
                es_maximo = False
                break
                
        if es_maximo:
            centros_filtrados.append((a, b, radio))
            
    return centros_filtrados
