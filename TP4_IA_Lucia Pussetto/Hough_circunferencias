        print("[2/3] Contornos extraídos.")
        
        # Ejecución del cubo de Hough
        acumulador, radios = transformada_hough_circulos(imagen_bordes, RADIO_MINIMO, RADIO_MAXIMO)
        
        # Extracción de centros depurados
        circulos_detectados = encontrar_centros_nms(acumulador, radios, UMBRAL_VOTOS_CIRCULO)
        print(f"[3/3] ¡Proceso concluído! Se detectaron {len(circulos_detectados)} cilindros.")

