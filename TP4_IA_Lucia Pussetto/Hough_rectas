import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import math

def detectar_bordes_basico(imagen_gris, umbral_brillo=128):
    """
    Filtro manual muy sencillo. Convierte la imagen a blanco y negro absoluto.
    Los píxeles que superen el 'umbral_brillo' serán considerados bordes (1).
    """
    matriz_pixeles = np.array(imagen_gris)
    bordes = np.zeros_like(matriz_pixeles)
    
    # Todo lo que sea más claro que el umbral, lo marcamos como borde
    bordes[matriz_pixeles > umbral_brillo] = 1 
    return bordes

def detectar_bordes_magnitud(imagen_gris, umbral_gradiente=100):
    """
    Filtro avanzado que calcula la magnitud del vector gradiente.
    Aísla los bordes estructurales fuertes y elimina el ruido interno.
    """
    img_arr = np.array(imagen_gris, dtype=float)
    
    # Matrices vacías para guardar los cambios
    diff_x = np.zeros_like(img_arr)
    diff_y = np.zeros_like(img_arr)
    
    # Calculamos la derivada en X (horizontal) y en Y (vertical)
    diff_x[:, :-1] = np.diff(img_arr, axis=1)
    diff_y[:-1, :] = np.diff(img_arr, axis=0)
    
    # Aplicamos Pitágoras para obtener la fuerza real del borde
    magnitud = np.sqrt(diff_x**2 + diff_y**2)
    
    # Filtramos por el umbral
    bordes = np.zeros_like(img_arr)
    bordes[magnitud > umbral_gradiente] = 1
    
    return bordes


def transformada_hough_rectas(imagen_bordes, resolucion_theta=1):
    """
    Implementación matemática de la Transformada de Hough desde cero.
    """
    alto, ancho = imagen_bordes.shape
    
    # 1. Definimos los posibles ángulos (theta) desde -90 a 90 grados
    thetas = np.deg2rad(np.arange(-90, 90, resolucion_theta))
    
    # 2. Calculamos la distancia máxima posible (la diagonal de la foto)
    diagonal = int(math.ceil(math.sqrt(ancho**2 + alto**2)))
    rhos = np.arange(-diagonal, diagonal + 1)
    
    # 3. Creamos nuestra matriz acumuladora llena de ceros (La urna de votos)
    acumulador = np.zeros((len(rhos), len(thetas)), dtype=int)
    
    # Obtenemos las coordenadas (y, x) de todos los píxeles que son bordes
    y_idxs, x_idxs = np.nonzero(imagen_bordes)
    
    print(f"Procesando {len(x_idxs)} píxeles de borde... Esto puede tardar unos segundos.")
    
    # 4. Fase de votación: Por cada píxel de borde, evaluamos todos los ángulos
    for i in range(len(x_idxs)):
        x = x_idxs[i]
        y = y_idxs[i]
        
        for j, theta in enumerate(thetas):
            # Aplicamos la ecuación polar
            rho = int(round(x * np.cos(theta) + y * np.sin(theta)))
            
            # Buscamos en qué índice de nuestro arreglo cae este rho
            rho_idx = np.argmin(np.abs(rhos - rho))
            
            # ¡Sumamos un voto en esa urna!
            acumulador[rho_idx, j] += 1
            
    return acumulador, thetas, rhos

def encontrar_picos_nms(acumulador, umbral_votos, vecindad=15):
    """
    Busca celdas que superen el umbral, pero aplica Supresión de No Máximos (NMS)
    para fusionar líneas que estén demasiado cerca unas de otras.
    """
    # 1. Encontramos todos los puntos que superan el umbral base
    picos_rho_brutos, picos_theta_brutos = np.where(acumulador > umbral_votos)
    
    # Extraemos cuántos votos tiene cada uno de esos puntos
    votos = acumulador[picos_rho_brutos, picos_theta_brutos]
    
    # 2. Los ordenamos del que tiene más votos al que tiene menos
    indices_ordenados = np.argsort(votos)[::-1]
    
    picos_filtrados_rho = []
    picos_filtrados_theta = []
    
    # 3. Filtramos los picos
    for idx in indices_ordenados:
        r = picos_rho_brutos[idx]
        t = picos_theta_brutos[idx]
        
        # Asumimos que este pico es válido hasta demostrar lo contrario
        es_maximo_local = True
        
        # Lo comparamos contra los picos ganadores que ya aceptamos
        for fr, ft in zip(picos_filtrados_rho, picos_filtrados_theta):
            # Si las variables matemáticas de la recta están dentro del radio de "vecindad"...
            if abs(r - fr) < vecindad and abs(t - ft) < vecindad:
                # Significa que es una línea casi idéntica a una que ya dibujamos. La descartamos.
                es_maximo_local = False
                break
        
        # Si pasó la prueba de vecindad, es el pico máximo de su zona y lo guardamos
        if es_maximo_local:
            picos_filtrados_rho.append(r)
            picos_filtrados_theta.append(t)
            
    return picos_filtrados_rho, picos_filtrados_theta

