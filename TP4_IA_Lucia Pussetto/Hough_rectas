import numpy as np  # para el manejo eficiente de matrices y operaciones matemáticas vectoriales
import matplotlib.pyplot as plt  #  librería gráfica para diseñar y mostrar los paneles con imágenes
from PIL import Image  # para abrir archivos de imagen y convertirlos a escala de grises
import math  

# =====================================================================
# 1. FILTRO MATEMÁTICO POR MAGNITUD DE GRADIENTE
# =====================================================================
def detectar_bordes_magnitud(imagen_gris, umbral_gradiente=100):
    """
    Filtro que calcula la fuerza del cambio de color entre píxeles vecinos.
    Aísla contornos estructurales fuertes y elimina regiones sólidas o texturas suaves.
    """
    # Convierte la imagen a una matriz numérica de tipo flotante para permitir cálculos decimales
    img_arr = np.array(imagen_gris, dtype=float)
    
    # Crea una matriz vacía (llena de ceros) del mismo tamaño para guardar las derivadas en el eje X
    diff_x = np.zeros_like(img_arr)
    # Crea una matriz vacía (llena de ceros) del mismo tamaño para guardar las derivadas en el eje Y
    diff_y = np.zeros_like(img_arr)
    
    # Resta cada píxel con su vecino derecho. El resultado se guarda ignorando la última columna
    diff_x[:, :-1] = np.diff(img_arr, axis=1)
    # Resta cada píxel con su vecino de abajo. El resultado se guarda ignorando la última fila
    diff_y[:-1, :] = np.diff(img_arr, axis=0)
    
    # Aplica el Teorema de Pitágoras (raíz de la suma de los cuadrados) para hallar la magnitud del vector gradiente
    magnitud = np.sqrt(diff_x**2 + diff_y**2)
    
    # Inicializa una matriz de ceros que representará el lienzo final en blanco y negro
    bordes = np.zeros_like(img_arr)
    # Si la magnitud del cambio supera el límite calibrado, el píxel se enciende pasando a valer 1 (borde activo)
    bordes[magnitud > umbral_gradiente] = 1
    
    # Devuelve la matriz binaria de bordes detectados
    return bordes

# =====================================================================
# 2. EL CORAZÓN DE HOUGH (MATRIZ ACUMULADORA)
# =====================================================================
def transformada_hough_rectas(imagen_bordes, resolucion_theta=1):
    """
    Implementación clásica que mapea píxeles del espacio cartesiano (x, y)
    hacia curvas en el espacio paramétrico (rho, theta).
    """
    # Obtiene las dimensiones en píxeles de la imagen bajo análisis
    alto, ancho = imagen_bordes.shape
    
    # Genera un arreglo con todos los ángulos posibles de -90 a 89 grados y los transforma a radianes
    thetas = np.deg2rad(np.arange(-90, 90, resolucion_theta))
    
    # Calcula la distancia máxima posible en la foto (la diagonal) usando Pitágoras
    diagonal = int(math.ceil(math.sqrt(ancho**2 + alto**2)))
    # Genera el rango completo de distancias posibles distribuidas desde -diagonal hasta +diagonal
    rhos = np.arange(-diagonal, diagonal + 1)
    
    # Crea la "urna de votación": una matriz de ceros donde las filas son distancias y las columnas ángulos
    acumulador = np.zeros((len(rhos), len(thetas)), dtype=int)
    
    # Encuentra las coordenadas de fila (y) y columna (x) de todos los píxeles que fueron marcados como bordes (1)
    y_idxs, x_idxs = np.nonzero(imagen_bordes)
    
    # Bucle principal: recorre uno a uno todos los píxeles de borde encontrados
    for i in range(len(x_idxs)):
        x = x_idxs[i]  # Extrae la coordenada X del píxel actual
        y = y_idxs[i]  # Extrae la coordenada Y del píxel actual
        
        # Para este píxel en particular, evalúa cómo se comportaría en los 180 ángulos posibles
        for j, theta in enumerate(thetas):
            # Aplica la ecuación polar de la recta para calcular la distancia perpendicular al origen
            rho = int(round(x * np.cos(theta) + y * np.sin(theta)))
            
            # Busca cuál es el índice de fila en el vector 'rhos' que más se aproxima al valor calculado
            rho_idx = np.argmin(np.abs(rhos - rho))
            
            # Suma un voto en la celda correspondiente del acumulador para registrar la coincidencia geométrica
            acumulador[rho_idx, j] += 1
            
    # Devuelve la matriz de votación y los vectores de referencia de los ejes paramétricos
    return acumulador, thetas, rhos

# =====================================================================
# 3. SUPRESIÓN DE NO MÁXIMOS (NMS)
# =====================================================================
def encontrar_picos_nms(acumulador, umbral_votos, vecindad=15):
    """
    Analiza la matriz de votación para extraer las rectas ganadoras,
    descartando duplicados o líneas superpuestas dentro de una misma región.
    """
    # Localiza los índices de todas las celdas del acumulador que superaron el umbral mínimo de votos exigidos
    picos_rho_brutos, picos_theta_brutos = np.where(acumulador > umbral_votos)
    
    # Obtiene la cantidad exacta de votos que acumuló cada uno de esos puntos candidatos
    votos = acumulador[picos_rho_brutos, picos_theta_brutos]
    
    # Ordena los índices de los candidatos de mayor a menor cantidad de votos recibidos
    indices_ordenados = np.argsort(votos)[::-1]
    
    # Inicializa las listas vacías donde se almacenarán las coordenadas de los máximos locales definitivos
    picos_filtrados_rho = []
    picos_filtrados_theta = []
    
    # Recorre los candidatos empezando por el más votado de todos
    for idx in indices_ordenados:
        r = picos_rho_brutos[idx]  # Distancia candidata actual
        t = picos_theta_brutos[idx]  # Ángulo candidato actual
        
        es_maximo_local = True  # Bandera lógica: asume que el pico es válido hasta comprobar lo contrario
        
        # Compara el candidato actual contra los picos que ya fueron aprobados y guardados previamente
        for fr, ft in zip(picos_filtrados_rho, picos_filtrados_theta):
            # Si la distancia y el ángulo están demasiado cerca (dentro del radio de vecindad)...
            if abs(r - fr) < vecindad and abs(t - ft) < vecindad:
                es_maximo_local = False  # Se identifica como una línea redundante (duplicada). Se marca falsa.
                break  # Rompe el bucle interno porque no hace falta seguir comparándola
                
        # Si la bandera sigue siendo verdadera, significa que es el pico más alto de su zona geográfica
        if es_maximo_local:
            picos_filtrados_rho.append(r)  # Agrega la distancia a la lista de ganadores confirmados
            picos_filtrados_theta.append(t)  # Agrega el ángulo a la lista de ganadores confirmados
            
    # Devuelve los índices depurados de las líneas que pasaron el filtro de exclusión
    return picos_filtrados_rho, picos_filtrados_theta

# =====================================================================
# 4. ANÁLISIS ESPACIAL POR CUADRANTES (DIVISIÓN Y CONQUISTA)
# =====================================================================
def hough_por_cuadrantes(imagen_bordes, divisiones=2, umbral_votos_local=50):
    """
    Fracciona la imagen en sectores pequeños para procesar los votos localmente.
    Evita que las líneas cortas queden eclipsadas por estructuras masivas.
    """
    # Extrae el tamaño completo de la imagen analizada
    alto_total, ancho_total = imagen_bordes.shape
    
    # Determina cuántos píxeles de alto medirá cada cuadrante de la rejilla
    paso_y = alto_total // divisiones
    # Determina cuántos píxeles de ancho medirá cada cuadrante de la rejilla
    paso_x = ancho_total // divisiones
    
    # Inicializa la lista maestra donde se agruparán las rectas ganadoras de todos los sectores
    lineas_globales = []
    
    # Imprime en la consola el estado actual del proceso para seguimiento del usuario
    print(f"Dividiendo la imagen en {divisiones * divisiones} cuadrantes de análisis...")
    
    # Bucle anidado para recorrer las filas de la cuadrícula
    for fila in range(divisiones):
        # Bucle anidado para recorrer las columnas de la cuadrícula
        for col in range(divisiones):
            # Define las coordenadas de inicio y fin para recortar la ventana actual
            y_ini = fila * paso_y
            y_fin = (fila + 1) * paso_y
            x_ini = col * paso_x
            x_fin = (col + 1) * paso_x
            
            # Extrae una submatriz que representa exclusivamente el sector aislado
            sub_imagen = imagen_bordes[y_ini:y_fin, x_ini:x_fin]
            
            # Si el cuadrante está vacío o casi no tiene píxeles activos, lo salta para no gastar procesador
            if np.sum(sub_imagen) < umbral_votos_local:
                continue
                
            # Ejecuta la transformada matemática de Hough operando únicamente en este recorte
            acumulador, thetas, rhos = transformada_hough_rectas(sub_imagen)
            
            # Filtra las votaciones de este sector usando Supresión de No Máximos local
            p_rho_idx, p_theta_idx = encontrar_picos_nms(acumulador, umbral_votos_local, vecindad=15)
            
            # Recorre los ganadores locales para proyectarlos de vuelta al lienzo entero
            for i in range(len(p_rho_idx)):
                rho_local = rhos[p_rho_idx[i]]  # Distancia calculada con respecto al origen del cuadrante
                theta = thetas[p_theta_idx[i]]  # El ángulo se mantiene idéntico en cualquier escala
                
                # Ecuación de corrección de origen: traslada la distancia local al marco absoluto de la imagen completa
                rho_global = rho_local + (x_ini * np.cos(theta)) + (y_ini * np.sin(theta))
                
                # Guarda la recta corregida en la lista global de resultados estructurales
                lineas_globales.append((rho_global, theta))
                
    # Devuelve el conjunto de todas las líneas recopiladas tras el barrido espacial
    return lineas_globales

