# 5. BLOQUE PRINCIPAL DE ORQUESTACIÓN Y CONFIGURACIÓN
# =====================================================================
if __name__ == "__main__":
    
    # --- PARÁMETROS DE CALIBRACIÓN DEFINIDOS POR EL USUARIO ---
    RUTA_IMAGEN = r'C:\Users\lucia\Downloads\motor2.png'  # Ruta absoluta del archivo usando 'r' para evitar errores Unicode
    UMBRAL_GRADIENTE = 79  # Tolerancia del filtro de contornos. Captura transiciones con este valor mínimo de fuerza
    CANTIDAD_DIVISIONES = 2  # Estructura de la rejilla. El número 2 divide el lienzo en una matriz de 2x2 (4 cuadrantes)
    VOTOS_LOCALES = 43  # Cantidad mínima de píxeles alineados requeridos para declarar una recta ganadora en un sector
    # ----------------------------------------------------------

    try:
        # Carga la imagen desde el disco duro usando el objeto PIL Image
        imagen_original = Image.open(RUTA_IMAGEN)
        # Transforma los canales de color (RGB) a un canal único de luminancia (Escala de grises)
        imagen_gris = imagen_original.convert('L')
        print("[1/3] Imagen cargada.")
        
        # Aplica el filtro matemático de derivadas para aislar los bordes geométricos limpios
        imagen_bordes = detectar_bordes_magnitud(imagen_gris, UMBRAL_GRADIENTE)
        print("[2/3] Contornos aislados matemáticamente.")
        
        # Desencadena el análisis espacial dividido para extraer los parámetros de todas las líneas
        lineas_finales = hough_por_cuadrantes(imagen_bordes, CANTIDAD_DIVISIONES, VOTOS_LOCALES)
        print(f"[3/3] ¡Completado! Se dibujarán {len(lineas_finales)} rectas maestras.")

        # --- BLOQUE DE RENDERIZADO VISUAL CON MATPLOTLIB ---
        # Inicializa una ventana de visualización estructurada en 1 fila y 3 columnas de paneles gráficos
        fig, axes = plt.subplots(1, 3, figsize=(15, 5))
        
        # Panel 1: Despliega la fotografía original a color del block de motor
        axes[0].imshow(imagen_original)
        axes[0].set_title('Imagen Original')
        axes[0].axis('off')  # Oculta las marcas numéricas de los ejes de coordenadas para limpieza estética
        
        # Panel 2: Muestra la matriz binaria del filtro por magnitud de gradiente
        axes[1].imshow(imagen_bordes, cmap='gray')
        axes[1].set_title(f'Bordes (Gradiente > {UMBRAL_GRADIENTE})')
        axes[1].axis('off')  # Oculta las marcas numéricas
        
        # Panel 3: Prepara la base para dibujar las rectas sobre la fotografía original
        axes[2].imshow(imagen_original)
        axes[2].set_title(f'Hough Espacial ({CANTIDAD_DIVISIONES}x{CANTIDAD_DIVISIONES} | Votos > {VOTOS_LOCALES})')
        axes[2].axis('off')  # Oculta las marcas numéricas
        
        # Bucle final de trazado: recorre las ecuaciones paramétricas ganadoras para proyectarlas en pantalla
        for rho, theta in lineas_finales:
            a = np.cos(theta)  # Componente director horizontal de la recta
            b = np.sin(theta)  # Componente director vertical de la recta
            x0 = a * rho       # Calcula el punto de anclaje inicial en el eje X
            y0 = b * rho       # Calcula el punto de anclaje inicial en el eje Y
            
            # Proyecta el primer extremo de la recta a una distancia lejana (3000 píxeles) en sentido positivo
            x1 = int(x0 + 3000 * (-b))
            y1 = int(y0 + 3000 * (a))
            
            # Proyecta el segundo extremo de la recta a una distancia lejana (3000 píxeles) en sentido opuesto
            x2 = int(x0 - 3000 * (-b))
            y2 = int(y0 - 3000 * (a))
            
            # Dibuja físicamente el segmento continuo sobre el tercer panel usando color rojo ('-r') y grosor de 2 píxeles
            axes[2].plot((x1, x2), (y1, y2), '-r', linewidth=2)
            
        # Organiza de forma compacta los paneles para evitar que las etiquetas se encimen o pisen entre sí
        plt.tight_layout()
        # Abre la ventana interactiva independiente en tu entorno de Windows mostrando las imágenes definitivas
        plt.show()

    # Bloque de contingencia por si se escribió incorrectamente la ubicación de la imagen en las variables iniciales
    except FileNotFoundError:
        print(f"ERROR: Verifica la ruta de '{RUTA_IMAGEN}'.")